---
import Logo from '@/assets/logo.svg';
import MainNav from '@/components/ui/mainav.astro';

// Set Props
interface Props {
  bgImage: string;
  subtitle: string;
}

// Get Props
const { subtitle, bgImage } = Astro.props;
---

<header class="relative min-h-72 pb-72">
  <div class="absolute inset-0" style={{ backgroundImage: `url(${bgImage})` }}></div>
  <div class="absolute inset-0 bg-black/60"></div>
  <div class="relative max-w-7xl mx-auto py-10">
    <div class="items-center flex flex-col lg:flex-row lg:justify-between">
      <a href="/">
        <Logo class="w-72 pb-4" />
      </a>
      <MainNav />
    </div>
    <h1 class="text-4xl font-black uppercase text-white text-center mt-10">{subtitle}</h1>
  </div>
</header>
